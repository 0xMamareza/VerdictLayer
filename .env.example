# Use mock for local demos.
# Use genlayer only after a public contract address is configured.
VITE_VERDICTLAYER_INTEGRATION_MODE=mock

VITE_GENLAYER_NETWORK_NAME=studionet
VITE_GENLAYER_RPC_URL=

# Contract address is public. Never put private keys, seed phrases, or wallet secrets here.
VITE_VERDICTLAYER_CONTRACT_ADDRESS=
