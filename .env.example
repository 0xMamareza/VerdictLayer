# Public browser configuration only. Every VITE_ value is visible in the built frontend.
# Use mock for local-only demos; use genlayer with the public testnet contract below.
VITE_VERDICTLAYER_INTEGRATION_MODE=genlayer

VITE_GENLAYER_NETWORK_NAME=studionet

# Optional. Leave blank to use the GenLayer SDK's configured public network default.
# Never place an authenticated or private RPC URL in a VITE_ variable.
VITE_GENLAYER_RPC_URL=

# Contract address is public. Never put private keys, seed phrases, or wallet secrets here.
VITE_VERDICTLAYER_CONTRACT_ADDRESS=0xf7931C9C809b31B516b6C8fF199cA2e7819165d5

# Development diagnostics are hidden by default on public deployments.
VITE_SHOW_GENLAYER_DIAGNOSTICS=false
